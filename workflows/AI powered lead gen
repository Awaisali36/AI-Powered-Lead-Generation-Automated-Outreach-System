      "parameters": {
        "jsCode": "// 1. Get the list of people from the previous node\nconst people = $input.first().json.people || [];\n\n// 2. Define a scoring system for titles\n// 1 = Highest, 5 = Lowest\nconst getScore = (title) => {\n  if (!title) return 5; // Treat no title as lowest priority\n  const t = title.toLowerCase();\n  \n  // Rank 1: C-Suite & Founders\n  if (t.includes('ceo') || t.includes('chief') || t.includes('founder')) return 1;\n  \n  // Rank 2: Presidents, Owners, Partners\n  if (t.includes('president') || t.includes('owner') || t.includes('partner')) return 2;\n  \n  // Rank 3: Vice Presidents\n  if (t.includes('vice president') || t.includes('vp')) return 3;\n  \n  // Rank 4: Directors & Heads\n  if (t.includes('head') || t.includes('director')) return 4;\n  \n  // Rank 5: Managers, Individual Contributors, and everyone else\n  return 5; \n};\n\n// 3. Sort the people by Rank\nconst rankedPeople = people.map(person => ({\n  ...person,\n  rank: getScore(person.title)\n})).sort((a, b) => a.rank - b.rank);\n\n// 4. Take only the Top 5\nconst top5 = rankedPeople.slice(0, 5);\n\n// 5. Prepare the payload for Apollo Enrichment\n// We include the 'rank' in the object. \n// Note: While we send 'rank' here, Apollo's API response in the next node \n// might not echo this back unless you merge the data later.\nconst details = top5.map(p => ({ \n  id: p.id,\n  rank: p.rank \n}));\n\nreturn [{ json: { details } }];"
      },
