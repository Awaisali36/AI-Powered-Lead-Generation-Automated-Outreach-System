    {
      "parameters": {
        "jsCode": "// 1. Get sent emails\nconst sentEmailsNodes = $('Get Sent Emails (Last 24h)').all();\n\n// 2. Get contacts\nconst contactsNodes = $input.all();\n\n// 3. Create Map\nconst contactMap = {};\n\ncontactsNodes.forEach(item => {\n  const contact = item.json;\n  const email = (contact['Email Address'] || '').toLowerCase().trim();\n  \n  if (email) {\n    contactMap[email] = {\n      rowNumber: contact.row_number,\n      currentAttempts: parseInt(contact['Contact Attempt'] || contact['Contact Attempt '] || 0) || 0,\n      lastContacted: contact['Last Contacted Date'] || null,\n      status: contact['Lead Status'] || ''\n    };\n  }\n});\n\nconst toUpdate = [];\nconst processedEmails = new Set();\n\nconsole.log(`Found ${sentEmailsNodes.length} sent emails.`);\nconsole.log(`Mapped ${Object.keys(contactMap).length} contacts from sheet.`);\n\nsentEmailsNodes.forEach((node, index) => {\n  const email = node.json;\n  \n  if (!email.To) {\n    if (index < 3) console.log(`Email #${index} missing 'To' field:`, email);\n    return;\n  }\n\n  // Robust Email Extraction\n  let rawTo = email.To;\n  let toEmail = rawTo;\n\n  if (rawTo.includes('<') && rawTo.match(/<([^>]+)>/)) {\n    toEmail = rawTo.match(/<([^>]+)>/)[1];\n  }\n  \n  toEmail = toEmail.toLowerCase().trim();\n\n  if (contactMap[toEmail]) {\n    const contact = contactMap[toEmail];\n    \n    // Get the sent date of THIS specific email\n    let sentDateStr;\n    try {\n      const dateVal = email.internalDate ? parseInt(email.internalDate) : Date.now();\n      sentDateStr = new Date(dateVal).toISOString().split('T')[0];\n    } catch (e) {\n      sentDateStr = new Date().toISOString().split('T')[0];\n    }\n\n    // Skip duplicates in this batch\n    if (processedEmails.has(toEmail)) return;\n\n    // ✅ FIX: Only update if the email was sent AFTER the last contacted date\n    // This prevents re-counting the same emails every hour\n    if (contact.lastContacted) {\n      const lastContactedDate = new Date(contact.lastContacted);\n      const emailSentDate = new Date(sentDateStr);\n      \n      // If email was sent on or before the last contacted date, skip it\n      if (emailSentDate <= lastContactedDate) {\n        console.log(`Skipping ${toEmail} - Email sent on ${sentDateStr} is not newer than last contact ${contact.lastContacted}`);\n        return;\n      }\n    }\n\n    console.log(`✅ MATCH FOUND: Updating ${toEmail} (Row ${contact.rowNumber})`);\n\n    toUpdate.push({\n      json: {\n        row_number: contact.rowNumber,\n        'Email Address': toEmail,\n        'Lead Status': 'Contacted',\n        'Last Contacted Date': sentDateStr,\n        'Contact Attempt': contact.currentAttempts + 1,\n        'Contact Attempt ': contact.currentAttempts + 1\n      }\n    });\n\n    processedEmails.add(toEmail);\n  } else {\n    if (index < 5) console.log(`❌ No match in sheet for sent email: \"${toEmail}\"`);\n  }\n});\n\nconsole.log(`Total rows to update: ${toUpdate.length}`);\n\nreturn toUpdate;"
      },
