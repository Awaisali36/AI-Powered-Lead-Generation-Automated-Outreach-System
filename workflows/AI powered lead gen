        "jsCode": "// WATERFALL & FOLLOW-UP LOGIC - GUARANTEED FOLLOW-UPS\nconst leads = $input.all().map(item => item.json);\nconst companies = {};\n\n// Get \"Today\" at Midnight (00:00:00) to compare calendar days only\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst FOLLOW_UP_GAP_DAYS = 2; // Days to wait (e.g., Contacted Mon -> Send Wed)\nconst NEW_EMAIL_LIMIT = 10; // Maximum NEW emails per day (first contact only)\nconst MAX_ATTEMPTS = 5; // Maximum follow-ups before stopping\n\n// 1. Group by Domain\nleads.forEach(lead => {\n  const domain = lead.domain || lead.company;\n  if (!companies[domain]) companies[domain] = [];\n  companies[domain].push(lead);\n});\n\n// Separate lists for new emails vs follow-ups\nconst newEmails = [];\nconst followUps = [];\nconst skipped = { noRank1: 0, maxedOut: 0, waitingGap: 0, invalidDate: 0 };\n\n// 2. Analyze each company - ONLY RANK 1 (MOST SENIOR)\nfor (const domain in companies) {\n  // Sort by Rank (1=CEO, 2=COO...)\n  const team = companies[domain].sort((a, b) => a.rank - b.rank);\n  \n  // Only consider Rank 1 leads\n  const rank1Lead = team.find(person => person.rank === 1);\n  \n  if (!rank1Lead) {\n    skipped.noRank1++;\n    continue;\n  }\n  \n  const person = rank1Lead;\n  const attempts = parseInt(person.attempts) || 0;\n  \n  // --- SCENARIO A: New Person (Never contacted) ---\n  if (attempts === 0) {\n    newEmails.push(person);\n    continue;\n  }\n  \n  // --- SCENARIO B: Maxed Out (5+ attempts) - No more follow-ups ---\n  if (attempts >= MAX_ATTEMPTS) {\n    skipped.maxedOut++;\n    continue;\n  }\n  \n  // --- SCENARIO C: Follow-Up Candidate (Contacted but under limit) ---\n  // ALWAYS attempt follow-up if gap is met - NO LIMIT ON FOLLOW-UPS\n  \n  // If no lastContact date, send follow-up immediately (data issue fallback)\n  if (!person.lastContact) {\n    console.log(`⚠️ ${person.email}: Missing lastContact date but has ${attempts} attempts. Sending follow-up.`);\n    followUps.push(person);\n    continue;\n  }\n\n  const lastDate = new Date(person.lastContact);\n  \n  // Check for Invalid Date\n  if (isNaN(lastDate.getTime())) {\n    console.log(`⚠️ ${person.email}: Invalid lastContact date \"${person.lastContact}\". Sending follow-up.`);\n    followUps.push(person);\n    skipped.invalidDate++;\n    continue;\n  }\n\n  // Normalize Last Contact to Midnight\n  lastDate.setHours(0, 0, 0, 0);\n  \n  // Calculate difference in days\n  const diffTime = today.getTime() - lastDate.getTime();\n  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));\n  \n  if (diffDays >= FOLLOW_UP_GAP_DAYS) {\n    // Gap met - SEND FOLLOW-UP (no limit)\n    console.log(`✅ ${person.email}: ${diffDays} days since last contact. Sending follow-up #${attempts + 1}`);\n    followUps.push(person);\n  } else {\n    // Gap not yet met\n    console.log(`⏳ ${person.email}: Only ${diffDays} day(s) since last contact. Waiting for ${FOLLOW_UP_GAP_DAYS - diffDays} more day(s).`);\n    skipped.waitingGap++;\n  }\n}\n\n// 3. Apply limit ONLY to new emails, ALL follow-ups go through\nconst limitedNewEmails = newEmails.slice(0, NEW_EMAIL_LIMIT);\n\n// Combine: ALL follow-ups + limited new emails\nconst toEmail = [...followUps, ...limitedNewEmails];\n\n// Summary Log\nconsole.log(`\\n=== WATERFALL SUMMARY ===`);\nconsole.log(`Total leads processed: ${leads.length}`);\nconsole.log(`Companies without Rank 1: ${skipped.noRank1}`);\nconsole.log(`Leads maxed out (${MAX_ATTEMPTS}+ attempts): ${skipped.maxedOut}`);\nconsole.log(`Leads waiting for gap: ${skipped.waitingGap}`);\nconsole.log(`Leads with invalid dates: ${skipped.invalidDate}`);\nconsole.log(`--- OUTPUT ---`);\nconsole.log(`Follow-ups scheduled: ${followUps.length} (ALL - no limit)`);\nconsole.log(`New emails: ${newEmails.length} found, ${limitedNewEmails.length} scheduled (limit: ${NEW_EMAIL_LIMIT})`);\nconsole.log(`Total emails to send: ${toEmail.length}`);\nconsole.log(`========================\\n`);\n\nreturn toEmail.map(i => ({ json: i }));"
