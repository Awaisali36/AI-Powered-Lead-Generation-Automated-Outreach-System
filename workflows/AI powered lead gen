mpany Domain'],\n      title: lead['Job Title'],\n      // Mapping \"Rank\" from sheet\n      rank: parseInt(lead['Rank']) || 5,\n      // Mapping \"Contact Attempt \" (Handling the space in your sheet header)\n      attempts: parseInt(lead['Contact Attempt'] || lead['Contact Attempt '] || 0),\n      // Mapping \"Last Contacted Date\"\n      lastContact: lead['Last Contacted Date'] || lead['Last Outreach Date'] \n    }\n  };\n});"
